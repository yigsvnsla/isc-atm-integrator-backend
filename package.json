{
    "name": "@isc/backend",
    "version": "0.0.1",
    "description": "",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "prepare": "husky",
        "build": "bun --bun nest build",
        "format": "bun --bun prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "bun --bun nest start --type-check --builder swc",
        "start:dev": "bun --bun nest start --watch --type-check --builder swc",
        "start:debug": "bun --bun nest start --debug --type-check --watch --builder swc",
        "start:prod": "bun --bun node dist/main",
        "start:cache": "REDISMS_PORT=6379 bun x redis-memory-server",
        "migration:run": "bun run build && bun --bun typeorm migration:run -d dist/infrastructure/database/data-source.js",
        "migration:revert": "bun run build && bun --bun typeorm migration:revert -d dist/infrastructure/database/data-source.js",
        "seed": "bun run build && bun --bun node dist/infrastructure/database/seeds/run-seed.js",
        "seed:create": "bun --bun typeorm-extension seed:create --name src/infrastructure/database/seeds/",
        "lint": "bun --bun eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "bun test src/ test/",
        "test:watch": "bun --bun jest --watch",
        "test:cov": "bun --bun jest --coverage",
        "test:debug": "bun --bun node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "bun --bun jest --config ./test/jest-e2e.json"
    },
    "dependencies": {
        "@keyv/redis": "^5.1.6",
        "@nestjs/cache-manager": "^3.1.3",
        "@nestjs/common": "^11.0.1",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.0.1",
        "@nestjs/cqrs": "^11.0.3",
        "@nestjs/event-emitter": "^3.1.0",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.0.1",
        "@nestjs/swagger": "^11.4.5",
        "@nestjs/terminus": "^11.1.1",
        "@nestjs/typeorm": "^11.0.3",
        "@scalar/nestjs-api-reference": "^1.2.9",
        "@swc/cli": "^0.8.1",
        "@swc/core": "^1.15.43",
        "bcryptjs": "^3.0.3",
        "cache-manager": "^7.2.9",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "cookie-parser": "^1.4.7",
        "csrf-csrf": "^4.0.3",
        "helmet": "^8.3.0",
        "nestjs-cls": "^6.2.1",
        "nestjs-resilience": "^3.1.2",
        "passport": "^0.7.0",
        "passport-custom": "^1.1.1",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "pg": "^8.22.0",
        "redis": "^6.1.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "typeorm": "^1.0.0",
        "typeorm-extension": "^3.9.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.2.0",
        "@eslint/js": "^9.18.0",
        "@faker-js/faker": "^10.5.0",
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.1",
        "@swc/jest": "^0.2.39",
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.0.0",
        "@types/passport": "^1.0.17",
        "@types/passport-jwt": "^4.0.1",
        "@types/passport-local": "^1.0.38",
        "@types/pg": "^8.20.0",
        "@types/supertest": "^7.0.0",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-prettier": "^5.2.2",
        "globals": "^17.0.0",
        "jest": "^30.0.0",
        "prettier": "^3.4.2",
        "redis-memory-server": "^0.17.0",
        "source-map-support": "^0.5.21",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.20.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.1.0"
    },
    "lint-staged": {
        "*.ts": [
            "prettier --write",
            "eslint --fix"
        ]
    }
}
